# Copy to .env and fill in. .env is gitignored and never committed.

# OpenAI API key (the assessment provides one). Used by BOTH the extraction
# pipeline and the Q&A agent.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# Model for extraction + the agent. Allowed by the assessment key:
#   gpt-4.1-mini (default), gpt-4o-mini, gpt-5-mini
OPENAI_MODEL=gpt-4.1-mini

# Postgres connection string (Supabase is just Postgres).
#
# Supabase: Dashboard -> Project Settings -> Database -> Connection string -> URI.
#   Use the direct connection or the Session pooler, and keep sslmode=require.
#   postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres?sslmode=require
#
# Local Docker Postgres (see README "Option B"):
#   postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
